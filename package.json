    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "preflight:prod": "node scripts/production-preflight.mjs",
    "lint": "tsc --noEmit",
    "test": "bun test src/utils/image.test.ts src/utils/input.test.ts src/utils/solution.test.ts src/utils/request.test.ts src/services/gemini.test.ts src/services/ai.test.ts src/services/aiCitation.test.ts src/services/openaiCompatible.test.ts src/services/providers/registry.test.ts src/services/news.test.ts src/services/wotd.test.ts src/services/workspaceTransfer.test.ts src/utils/followUpContext.test.ts",
    "deploy": "bun run preflight:prod && bun run build && wrangler deploy",
    "cf:whoami": "wrangler whoami"
  },
  "dependencies": {
    "@asciidoctor/core": "^3.0.4",
    "@google/genai": "^1.29.0",
    "@tailwindcss/typography": "^0.5.19",
    "html5-qrcode": "^2.3.8",
    "katex": "^0.16.38",
    "lucide-react": "^0.546.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "smiles-drawer": "^2.1.7"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.30.2",
    "@tailwindcss/vite": "^4.1.14",
    "@types/node": "^22.14.0",
    "@types/qrcode": "^1.5.6",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "playwright": "^1.59.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vite-plugin-pwa": "^1.2.0",
    "wrangler": "^4.78.0"
  }
