# Optional auth + sync foundation.
VITE_CLERK_PUBLISHABLE_KEY="pk_test_..."
VITE_CONVEX_URL="https://your-project.convex.cloud"

# Required only when Convex uses Clerk auth.
CLERK_JWT_ISSUER_DOMAIN="https://your-clerk-domain.clerk.accounts.dev"
USER_KEY_ENCRYPTION_SECRET="replace-with-a-long-random-secret"

# Optional Convex-side bridge for MiniMax advanced image understanding.
# Set these in Convex if you enable the signed-in secure MiniMax advanced path.
MINIMAX_ADVANCED_BRIDGE_URL="https://your-bridge.example.com/minimax/image"
MINIMAX_ADVANCED_BRIDGE_TOKEN="optional-bridge-bearer-token"

# Optional env-provided Gemini fallback.
GEMINI_API_KEY="your-gemini-api-key"

# Optional Google-backed search keys. The app has fallbacks for some media flows.
GOOGLE_API_KEY="your-google-api-key"

# Optional model overrides.
# GEMINI_FAST_MODEL="gemini-2.5-flash"
# GEMINI_GROUNDED_MODEL="gemini-2.5-flash"
# GEMINI_PRO_MODEL="gemini-2.5-pro"
