# Recommended default: Cloudflare + browser-local mode.
# No account layer is required.

# Optional OpenRouter attribution referer.
OPENROUTER_REFERER="https://your-app-domain.example"

# Optional env-provided Gemini fallback.
GEMINI_API_KEY="your-gemini-api-key"

# Optional Google-backed search keys. The app has fallbacks for some media flows.
GOOGLE_API_KEY="your-google-api-key"

# Optional Google Custom Search Engine ID (default is hardcoded fallback).
# VITE_SEARCH_ENGINE_ID="017576662512468239146:2152321705"

# Optional model overrides.
# GEMINI_FAST_MODEL="gemini-2.5-flash"
# GEMINI_GROUNDED_MODEL="gemini-2.5-flash"
# GEMINI_PRO_MODEL="gemini-2.5-pro"
